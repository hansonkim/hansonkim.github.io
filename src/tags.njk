---
pagination:
  data: collections
  size: 1
  alias: tag
  filter:
    - all
    - posts
    - tagList
permalink: /tags/{{ tag | slugify }}/
layout: base.njk
---

<div class="blog-header text-center mb-10 px-5 py-10 rounded-2xl">
  <h1 class="mb-8 text-gray-800 font-bold text-2xl">태그: {{ tag }}</h1>
  <p class="text-gray-600 text-lg mt-2.5">{{ collections[tag].length }}개의 글</p>
</div>

<section class="posts">
  <ul class="post-list list-none">
    {%- set sortedPosts = collections[tag] | sort(false, false, 'date') | reverse -%}
    {%- for post in sortedPosts -%}
    {% set headingLevel = "h2" %}{% set showTags = true %}{% include "post-card.njk" %}
    {%- endfor -%}
  </ul>
</section>
