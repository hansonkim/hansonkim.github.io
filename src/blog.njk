---
layout: base.njk
title: Blog
permalink: /blog/
---

<div class="blog-header text-center mb-10 px-5 py-10 rounded-2xl">
  <h1 class="mb-8 text-gray-800 font-bold text-2xl">블로그</h1>
  <p class="text-gray-600 text-lg mt-2.5">모든 글 보기</p>
</div>

<section class="posts">
  <ul class="post-list list-none">
    {%- for post in collections.posts -%}
    {% set headingLevel = "h2" %}{% set showTags = true %}{% include "post-card.njk" %}
    {%- endfor -%}
  </ul>
</section>
