---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

function getReadingTime(body: string) {
  return Math.ceil(body.split(/\s+/).length / 200) + '분 읽기';
}
---

<BaseLayout title="Hanson's Blog">
  <section class="hero">
    <div class="container">
      <h1>Hanson's Blog</h1>
      <p>개발과 기술에 대한 생각을 기록합니다.</p>
      <a href="/blog" class="hero-link">
        블로그 보기
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="container" style="padding-bottom: 3rem;">
      <h2 class="section-title">최근 글</h2>
      <div class="blog-grid">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.id}
            tags={post.data.tags}
            category={post.data.category}
            readingTime={post.body ? getReadingTime(post.body) : '1분 읽기'}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
